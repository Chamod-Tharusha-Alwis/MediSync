# ==============================================================
# MEDISYNC GLOBAL ENVIRONMENT VARIABLES CONFIGURATION (EXAMPLE)
# ==============================================================
# Copy these keys into your local server/.env and ml-engine/.env
# files and configure the values appropriately for local running.

# ─── SERVER CONFIGURATION (server/.env) ───────────────────────
PORT=5005
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB Database Connection URIs
MONGO_URI=<YOUR_MONGO_CONNECTION_STRING>
MONGO_URI_TEST=<YOUR_MONGO_TEST_CONNECTION_STRING>

# Authentication Token Secrets
JWT_SECRET=<YOUR_32_BYTE_HEX_JWT_SECRET>
JWT_REFRESH_SECRET=<YOUR_32_BYTE_HEX_JWT_REFRESH_SECRET>

# PII Database Cryptographic Field Encryption
ENCRYPTION_KEY=<YOUR_32_CHARACTER_ENCRYPTION_KEY>

# Vault Root Secret Engine Token
VAULT_TOKEN=myroot

# SMTP Email Dispatch Server (Gmail App Password config)
EMAIL_USER=<YOUR_SENDER_EMAIL>
EMAIL_PASS=<YOUR_EMAIL_APP_PASSWORD>

# Cloudinary Secure Blob Store (Encrypted PDF Lab Reports)
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>

# Flask Python ML Engine Authentication & Routing
INTERNAL_API_KEY=<YOUR_INTERNAL_API_KEY>
ML_ENGINE_URL=http://127.0.0.1:5001


# ─── PYTHON ML ENGINE CONFIGURATION (ml-engine/.env) ──────────
NODE_API_URL=http://localhost:5005
# INTERNAL_API_KEY must match the key declared in the server/.env
# INTERNAL_API_KEY=<YOUR_INTERNAL_API_KEY>
